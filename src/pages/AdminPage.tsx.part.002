          },
          { merge: true }
        );
      }
      setForm({ databaseCode: "", itemCode: "", itemType: "", item: "", unitOfMeasure: FALLBACK_UNIT, cost: "" });
      setEditingItemId(null);
      onMessage("Item saved.");
      await onRefresh();
    } catch {
      onError("Could not save item.");
    }
  }

  async function toggleItem(item: Item) {
    try {
      await updateDoc(itemDoc(item.