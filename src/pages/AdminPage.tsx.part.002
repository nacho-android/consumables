            updatedBy: actorId
          },
          { merge: true }
        );
        await setDoc(
          itemCostDoc(newItemId),
          {
            itemId: newItemId,
            databaseCode: trimmed.databaseCode,
            itemCode: trimmed.itemCode,
            itemType: trimmed.itemType,
            itemName: trimmed.item,
            cost: parsedCost,
            createdAt: serverTimestamp(),
